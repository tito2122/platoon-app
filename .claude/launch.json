{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Firebase Hosting (local)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["firebase", "serve", "--only", "hosting"],
      "port": 5000
    },
    {
      "name": "Static HTTP Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "3000"],
      "port": 3000
    }
  ]
}
