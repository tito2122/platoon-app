<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="סטטיסטיקות"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="16dp" />

        <!-- Stats cards row 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginEnd="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvTotal" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="28sp" android:textStyle="bold" android:textColor="@color/primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="סה\"כ חיילים" android:textSize="12sp" android:textColor="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginStart="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvPresent" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="28sp" android:textStyle="bold" android:textColor="@color/status_present" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="נוכחים" android:textSize="12sp" android:textColor="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Stats cards row 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginEnd="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvAbsent" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="28sp" android:textStyle="bold" android:textColor="@color/status_absent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="נעדרים" android:textSize="12sp" android:textColor="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginStart="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvLeave" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="28sp" android:textStyle="bold" android:textColor="@color/status_leave" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="בחופשה" android:textSize="12sp" android:textColor="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Stats cards row 3 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginEnd="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvMissing" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="28sp" android:textStyle="bold" android:textColor="@color/error" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="חסרים" android:textSize="12sp" android:textColor="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginStart="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvHofpa" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="28sp" android:textStyle="bold" android:textColor="@color/secondary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="חו\"פ" android:textSize="12sp" android:textColor="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Present percentage -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="אחוז נוכחות"
                        android:textStyle="bold" android:textSize="14sp" />
                    <TextView android:id="@+id/tvPresentPercent" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0%"
                        android:textStyle="bold" android:textColor="@color/primary" />
                </LinearLayout>
                <ProgressBar android:id="@+id/progressPresent"
                    android:layout_width="match_parent" android:layout_height="12dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:max="100" android:progress="0"
                    android:progressTint="@color/primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Role breakdown -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="פירוט תפקידים" android:textStyle="bold" android:textSize="15sp"
                    android:layout_marginBottom="8dp" android:textColor="@color/text_primary" />
                <LinearLayout android:id="@+id/llRoles" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
